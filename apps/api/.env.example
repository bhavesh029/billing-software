DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"
PORT=4000
CORS_ORIGIN="http://localhost:3000"

# 32-byte key, base64-encoded (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
FIELD_ENCRYPTION_KEY=""

# Supabase > Settings > API > JWT Secret (used to validate browser sessions on the API)
SUPABASE_JWT_SECRET=""

# Optional: server-side Storage signed uploads for logos
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_LOGO_BUCKET="org-logos"
